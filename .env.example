# MongoDB (local ou Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/corelab?appName=Cluster0

# JWT — générer avec : openssl rand -hex 32
JWT_SECRET=your_random_secret_here_min_32_chars

# Serveur
PORT=4242
NODE_ENV=development

# CORS — URL du frontend (virgule pour plusieurs origines)
CORS_ORIGIN=http://localhost:3000
